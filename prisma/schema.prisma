generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id              String                @id
  initials        String
  bg              String                @default("#EEEDFE")
  fg              String                @default("#3C3489")
  name            String
  contact         String
  mobile          String
  email           String                @default("")
  gst             String                @default("")
  pan             String                @default("")
  address_line    String                @default("")
  city            String                @default("")
  district        String                @default("")
  state           String                @default("")
  pin             String                @default("")
  status          String                @default("Active")
  created_at      String
  updated_at      String?
  inquiries       Inquiry[]
  equipment_rates ClientEquipmentRate[]

  @@map("clients")
}

model Inquiry {
  id                 String @id
  client_id          String
  client             Client @relation(fields: [client_id], references: [id], onDelete: Cascade)
  event_type         String
  event_name         String @default("")
  start_date         String
  end_date           String
  start_time         String @default("")
  end_time           String @default("")
  venue              String @default("")
  notes              String @default("")
  status             String @default("New")
  department         String @default("VIDEO") // "VIDEO" | "LED" | "MERGED"
  power_requirements String @default("")
  tables_space       String @default("")
  other_requirements String @default("")

  // LED Specific Fields (Nullable to support Video-only inquiries)
  screen_width     Float?
  screen_height    Float?
  screen_area_sqft Float?
  total_cabinets   Int?
  led_type         String? // P4 | P3 | P2 | FLOOR | P4_CURVED
  rate_per_sqft    Float?
  location         String  @default("INDOOR") // INDOOR | OUTDOOR
  stage_type       String? // Main stage, Backdrop, etc.

  // LED Dispatch fields
  dispatch_date   String?
  dispatch_time   String? @default("06:00 AM")
  vehicle1_number String?
  vehicle1_driver String?
  vehicle2_number String?
  vehicle2_driver String?

  created_at         String
  updated_at         String?
  quotations         Quotation[]
  staff_assignments  StaffAssignment[]
  staff_payments     StaffPayment[]
  equipment_bookings EquipmentBooking[]
  dispatch_boxes     LedDispatchBox[]

  @@index([client_id])
  @@index([status, start_date])
  @@index([department])
  @@map("inquiries")
}

model Quotation {
  id              String    @id
  inquiry_id      String
  inquiry         Inquiry   @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  client_name     String
  event_name      String
  quote_no        String
  start_date      String
  end_date        String
  days            Int       @default(1)
  venue           String    @default("")
  status          String    @default("Draft")
  equipment       String    @default("[]")
  subtotal        Float     @default(0)
  cgst            Float     @default(0)
  sgst            Float     @default(0)
  total           Float     @default(0)
  revision_number Int       @default(0)
  signed_copy_url String    @default("")
  created_at      String
  updated_at      String?
  sent_at         String?
  approved_at     String?
  invoices        Invoice[]

  @@map("quotations")
}

model Invoice {
  id                  String    @id
  quotation_id        String
  quotation           Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  invoice_no          String
  client_name         String
  event_name          String
  start_date          String
  end_date            String
  venue               String    @default("")
  videography_amount  Float     @default(0)
  photography_amount  Float     @default(0)
  advance             Float     @default(0)
  balance             Float     @default(0)
  status              String    @default("Unpaid")
  advance_received    Int       @default(0)
  advance_received_at String?
  advance_ref         String    @default("")
  advance_method      String    @default("")
  balance_received    Int       @default(0)
  balance_received_at String?
  balance_ref         String    @default("")
  balance_method      String    @default("")
  hdd_delivered       Int       @default(0)
  hdd_size_gb         Int?
  deinstall_done      Int       @default(0) // 1 = done, 0 = pending
  created_at          String
  updated_at          String?
  due_date            String

  @@map("invoices")
}

model CalendarEvent {
  id    String @id
  date  Int
  month Int
  year  Int
  label String
  type  String

  @@map("calendar_events")
}

model Kit {
  id                 Int                @id @default(autoincrement())
  name               String             @unique
  description        String?
  main_body_id       Int?
  department         String             @default("VIDEO") // "VIDEO" | "LED"
  created_at         String
  equipment          Equipment[]
  equipment_bookings EquipmentBooking[]

  @@map("kits")
}

model Equipment {
  id             Int                @id @default(autoincrement())
  product_name   String
  category       String
  quantity       Int                @default(1)
  quantity_unit  String             @default("pieces") // "pieces" | "pair" | "metre"
  serial_number  String?
  body_name      String?
  department     String             @default("VIDEO") // "VIDEO" | "LED"
  kit_id         Int?
  kit            Kit?               @relation(fields: [kit_id], references: [id], onDelete: SetNull)
  resp_person    String?
  purchase_date  String?
  purchase_from  String?
  bill_number    String?
  purchase_price Float?
  status         String             @default("AVAILABLE")
  notes          String?
  created_at     String
  updated_at     String?
  bookings       EquipmentBooking[]
  ownership_type String             @default("INHOUSE") // "INHOUSE" | "VENDOR" | "STAFF"
  vendor_id      Int?
  vendor         Vendor?            @relation(fields: [vendor_id], references: [id], onDelete: SetNull)
  owner_staff_id Int?
  owner_staff    Staff?             @relation("StaffOwnedEquipment", fields: [owner_staff_id], references: [id], onDelete: SetNull)

  // Per-day rental rate charged to clients for this equipment (default; client overrides live in client_equipment_rates)
  default_rate Float?
  // Client-specific rate overrides for this equipment
  client_rates ClientEquipmentRate[]

  @@index([owner_staff_id])
  @@map("equipment")
}

model Vendor {
  id                 Int                @id @default(autoincrement())
  name               String
  phone              String
  email              String?
  specialization     String?
  city               String?
  gst_number         String?
  notes              String?
  is_active          Int                @default(1)
  created_at         String
  equipment_bookings EquipmentBooking[]
  equipments         Equipment[]

  @@map("vendors")
}

model Staff {
  id                     Int               @id @default(autoincrement())
  name                   String
  phone                  String
  role                   String
  staff_type             String
  payment_type           String
  department             String            @default("VIDEO") // "VIDEO" | "LED" | "BOTH"
  rate_per_day           Float?
  monthly_salary         Float?
  with_equipment         Int               @default(0)
  equipment_desc         String?
  // Extra per-day rate added when this staff brings their own equipment to a job
  equipment_rate_per_day Float?
  aadhar_number          String?
  aadhar_front           String?
  aadhar_back            String?
  is_active              Int               @default(1)
  created_at             String
  updated_at             String?
  assignments            StaffAssignment[]
  payments               StaffPayment[]
  owned_equipment        Equipment[]       @relation("StaffOwnedEquipment")
  equipment_rentals      EquipmentBooking[] @relation("StaffEquipmentRentals")

  @@map("staff")
}

model StaffAssignment {
  id                     Int            @id @default(autoincrement())
  staff_id               Int
  staff                  Staff          @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  inquiry_id             String
  inquiry                Inquiry        @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  position_no            Int?
  position_name          String?
  days_assigned          Int
  rate_per_day           Float
  // Whether the staff brought their own equipment on this job, and the extra per-day rate for it
  with_equipment         Int            @default(0)
  equipment_rate_per_day Float          @default(0)
  total_amount           Float
  is_duplicate           Int            @default(0)
  confirmed_dup          Int            @default(0)
  reporting_time         String         @default("09:00 AM")
  created_at             String
  payments               StaffPayment[]

  @@index([inquiry_id])
  @@index([staff_id])
  @@map("staff_assignments")
}

model StaffPayment {
  id             Int              @id @default(autoincrement())
  staff_id       Int
  staff          Staff            @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  assignment_id  Int?
  assignment     StaffAssignment? @relation(fields: [assignment_id], references: [id], onDelete: SetNull)
  inquiry_id     String?
  inquiry        Inquiry?         @relation(fields: [inquiry_id], references: [id], onDelete: SetNull)
  amount         Float
  payment_type   String
  payment_method String
  reference_no   String?
  month          String?
  paid_at        String
  paid_by_id     String?
  notes          String?

  @@index([staff_id])
  @@index([inquiry_id])
  @@index([month])
  @@map("staff_payments")
}

model EquipmentBooking {
  id                  Int        @id @default(autoincrement())
  inquiry_id          String
  inquiry             Inquiry    @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  equipment_id        Int?
  equipment           Equipment? @relation(fields: [equipment_id], references: [id], onDelete: SetNull)
  kit_id              Int?
  kit                 Kit?       @relation(fields: [kit_id], references: [id], onDelete: SetNull)
  position            String?
  booked_from         String
  booked_to           String
  status              String     @default("BOOKED")
  vendor_id           Int?
  vendor              Vendor?    @relation(fields: [vendor_id], references: [id], onDelete: SetNull)
  vendor_cost_per_day Float?
  total_vendor_cost   Float?
  confirmed_by_id     String?
  confirmed_at        String?

  // Staff-owned equipment rental: rental is credited to the equipment OWNER,
  // regardless of which staff member uses the equipment at the event.
  // owner_staff_id snapshots the owner at the time rental is recorded.
  rental_owner_staff_id   Int?
  rental_owner_staff      Staff? @relation("StaffEquipmentRentals", fields: [rental_owner_staff_id], references: [id], onDelete: SetNull)
  rental_rate_per_day     Float?
  total_rental            Float?

  @@index([inquiry_id])
  @@index([booked_from, booked_to])
  @@index([equipment_id])
  @@index([kit_id])
  @@index([rental_owner_staff_id])
  @@map("equipment_bookings")
}

model User {
  id         String  @id @default(uuid())
  username   String  @unique
  name       String  @default("")
  password   String
  role       String  @default("Admin")
  is_active  Int     @default(1)
  created_at String
  updated_at String?

  @@map("users")
}

model LedDispatchBox {
  id         Int     @id @default(autoincrement())
  inquiry_id String
  inquiry    Inquiry @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  box_number Int
  contents   String
  cabinets   Int
  vehicle    String // "Vehicle 1" | "Vehicle 2"
  source     String // "BK_MEDIA" | "VENDOR"

  @@map("led_dispatch_boxes")
}

model RolePermission {
  id         Int    @id @default(autoincrement())
  role       String
  permission String

  @@unique([role, permission])
  @@map("role_permissions")
}

// Generic user-managed option lists (e.g. staff roles, quotation positions).
// Lets users add their own choices to dropdowns without a code change.
model OptionList {
  id         Int     @id @default(autoincrement())
  type       String // "STAFF_ROLE" | "QUOTATION_POSITION"
  value      String // the option text shown in the dropdown
  // Optional metadata for quotation positions (default equipment + rate)
  meta_equip String?
  meta_rate  Float?
  sort_order Int     @default(0)
  is_active  Int     @default(1)
  created_at String

  @@unique([type, value])
  @@index([type])
  @@map("option_lists")
}

// Per-client rate override for a specific equipment item.
// If no row exists for a (client, equipment) pair, the equipment's default_rate is used.
model ClientEquipmentRate {
  id           Int       @id @default(autoincrement())
  client_id    String
  client       Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  equipment_id Int
  equipment    Equipment @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  rate         Float
  created_at   String
  updated_at   String?

  @@unique([client_id, equipment_id])
  @@index([client_id])
  @@index([equipment_id])
  @@map("client_equipment_rates")
}
